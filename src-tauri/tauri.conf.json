{
  "$schema": "https://raw.githubusercontent.com/niconiahi/tauri-schema/v2/schema.json",
  "productName": "Claude Code Launcher",
  "version": "0.1.0",
  "identifier": "com.claude-launcher.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Code Launcher",
        "width": 900,
        "height": 650,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
